# ========================================
# Variáveis de Ambiente - Docker SAW
# ========================================
# Copie este arquivo para .env e configure os valores

# Banco de dados
DB_HOST=localhost
DB_USER=seu_usuario
DB_PASS=sua_senha_aqui
DB_NAME=saw
DB_PORT=3306

# JWT Secret (gere um valor único)
JWT_SECRET=gere_uma_chave_secreta_forte

# Aplicação
APP_NAME=SAW
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost:7080

# Logs
LOG_LEVEL=warning
LOG_CHANNEL=stack
